{
  "name": "novel-ai-writer",
  "version": "2.0.0",
  "description": "AI 小说写作软件 — 学习小说风格，辅助长篇小说创作",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n renderer,electron \"vite\" \"wait-on http://localhost:5173 && node scripts/build-electron.mjs && node scripts/start-electron.cjs\"",
    "build": "vite build && node scripts/build-electron.mjs",
    "package": "npm run build && electron-builder"
  },
  "keywords": [
    "novel",
    "ai",
    "writing",
    "electron",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "docx": "^8.5.0",
    "jspdf": "^2.5.2",
    "mammoth": "^1.12.0",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "sql.js": "^1.14.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.19.12",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.7",
    "wait-on": "^7.2.0"
  }
}
